{
    // 本文件主要定义了通用 UI 的行为和显示内容
    // 可参考文档和示例添加更多您需要的功能
    // 文档：https://maafw.xyz/docs/3.3-ProjectInterfaceV2
    // 示例：https://github.com/MaaXYZ/MaaFramework/blob/main/sample/interface.json
    "interface_version": 2,
    "name": "MaaZjcs",
    "label": "MaaZjcs",
    "icon": "./icon.png",
    "description": "这是一个使用 MaaFramework 创建的杖剑传说自动化项目。",
    "license": "MIT",
    "welcome": "欢迎使用 MaaZjcs!",
    // 填写项目地址和版本号可实现自动更新功能
    "github": "https://github.com/lazygurus/MaaZjcs",
    "version": "1.0.1",
    // Mirror酱为第三方分发服务，新项目默认关闭
    // 若有需要请联系 Mirror酱 开通，直接自行开启是无法使用的
    // "mirrorchyan_rid": "MaaXXX",
    // "mirrorchyan_multiplatform": true,
    "controller": [
        {
            "name": "ADB",
            "label": "模拟器",
            "type": "Adb",
            "display_short_side": 720 // 默认缩放分辨率的短边长度
        }
    ],
    "resource": [
        {
            "name": "官服",
            "path": [
                "./resource/base"
            ]
        },
        {
            "name": "B 服",
            "path": [
                "./resource/base",
                "./resource/bilibili"
            ]
        }
    ],
    "task": [
        {
            "name": "启动游戏",
            "entry": "StartUp"
        },
        {
            "name": "商店购买",
            "entry": "Store",
            "option": [
                "晨星商店"
            ]
        }
    ],
    "option": {
        "晨星商店": {
            "type": "switch",
            "description": "决定是否购买需要晨星的商品",
            "cases": [
                {
                    "name": "Yes",
                    "label": "购买",
                    "description": "用晨星购买商品"
                },
                {
                    "name": "No",
                    "label": "不购买",
                    "description": "不用晨星购买商品",
                    "pipeline_override": {
                        "TreasureSlot2": {
                            "enabled": false
                        },
                        "TreasureSlot3": {
                            "enabled": false
                        },
                        "TreasureSlot4": {
                            "enabled": false
                        },
                        "TreasureSlot5": {
                            "enabled": false
                        },
                        "TreasureSlot6": {
                            "enabled": false
                        },
                        "TreasureSlot7": {
                            "enabled": false
                        },
                        "TreasureSlot8": {
                            "enabled": false
                        },
                        "TreasureSlot9": {
                            "enabled": false
                        }
                    }
                }
            ]
        }
    },
    "import": [
        "preset/MainAccount",
        "preset/SideAccount"
    ]
}