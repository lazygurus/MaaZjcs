{
    // 本文件主要定义了通用 UI 的行为和显示内容
    // 可参考文档和示例添加更多您需要的功能
    // 文档：https://maafw.xyz/docs/3.3-ProjectInterfaceV2
    // 示例：https://github.com/MaaXYZ/MaaFramework/blob/main/sample/interface.json
    "interface_version": 2,
    "name": "MaaZjcs",
    "label": "MaaZjcs",
    "icon": "./icon.png",
    "description": "这是一个使用 MaaFramework 创建的杖剑传说自动化项目。",
    "license": "MIT",
    "welcome": "欢迎使用 MaaZjcs!",
    // 填写项目地址和版本号可实现自动更新功能
    "github": "https://github.com/lazygurus/MaaZjcs",
    "version": "1.0.1",
    // Mirror酱为第三方分发服务，新项目默认关闭
    // 若有需要请联系 Mirror酱 开通，直接自行开启是无法使用的
    // "mirrorchyan_rid": "MaaXXX",
    // "mirrorchyan_multiplatform": true,
    "controller": [
        {
            "name": "ADB",
            "label": "模拟器",
            "type": "Adb",
            "display_short_side": 720 // 默认缩放分辨率的短边长度
        }
    ],
    "resource": [
        {
            "name": "官服",
            "path": [
                "./resource/base"
            ]
        },
        {
            "name": "B 服",
            "path": [
                "./resource/base",
                "./resource/bilibili"
            ]
        }
    ],
    "task": [
        {
            "name": "启动游戏",
            "entry": "StartUp"
        },
        {
            "name": "商店购买",
            "entry": "Store",
            "option": [
                "晨星商店"
            ]
        },
        {
            "name": "领取邮件",
            "entry": "Mail"
        },
        {
            "name": "使用素材",
            "entry": "Material",
            "option": [
                "选择素材"
            ]
        },
        {
            "name": "竞技场",
            "entry": "Arena",
            "option": [
                "挑战次数"
            ]
        },
        {
            "name": "找回奖励",
            "entry": "RewardRecovery"
        },
        {
            "name": "使用体力",
            "entry": "Energy",
            "option": [
                "体力选择",
                "体力使用次数"
            ]
        },
        {
            "name": "领小推车",
            "entry": "Cart"
        },
        {
            "name": "命运之树",
            "entry": "Tree",
            "option": [
                "购买宠物素材"
            ]
        },
        {
            "name": "使用命运果实",
            "entry": "Fruit"
        },
        {
            "name": "羁绊冒险",
            "entry": "Commission"
        },
        {
            "name": "公会",
            "entry": "Guild"
        },
        {
            "name": "领取奖励",
            "entry": "Prize"
        },
        // {
        //     "name": "测试功能",
        //     "entry": "CardPage"
        // }
        // {
        //     "name": "清理家园",
        //     "entry": "CleanHomeAnimal"
        // },
        // {
        //     "name": "识别当前页面文字",
        //     "entry": "OcrCurrentPage"
        // },
        // {
        //     "name": "识别指定图片",
        //     "entry": "RecognizePicture"
        // }
    ],
    "option": {
        "晨星商店": {
            "type": "switch",
            "description": "决定是否购买需要晨星的商品",
            "default_case": "Yes",
            "cases": [
                {
                    "name": "Yes",
                    "label": "购买",
                    "description": "用晨星购买商品"
                },
                {
                    "name": "No",
                    "label": "不购买",
                    "description": "不用晨星购买商品",
                    "pipeline_override": {
                        "TreasureSlot2": {
                            "enabled": false
                        },
                        "TreasureSlot3": {
                            "enabled": false
                        },
                        "TreasureSlot4": {
                            "enabled": false
                        },
                        "TreasureSlot5": {
                            "enabled": false
                        },
                        "TreasureSlot6": {
                            "enabled": false
                        },
                        "TreasureSlot7": {
                            "enabled": false
                        },
                        "TreasureSlot8": {
                            "enabled": false
                        },
                        "TreasureSlot9": {
                            "enabled": false
                        }
                    }
                }
            ]
        },
        "选择素材": {
            "type": "select",
            "label": "选择素材",
            "default_case": "金矿",
            "cases": [
                {
                    "name": "铁矿",
                    "pipeline_override": {
                        "Iron": {
                            "enabled": true
                        }
                    }
                },
                {
                    "name": "金矿",
                    "pipeline_override": {
                        "Gold": {
                            "enabled": true
                        }
                    }
                },
                {
                    "name": "精华",
                    "pipeline_override": {
                        "Monster": {
                            "enabled": true
                        }
                    }
                },
                {
                    "name": "砂矿",
                    "pipeline_override": {
                        "Gravel": {
                            "enabled": true
                        }
                    }
                }
            ]
        },
        "挑战次数": {
            "type": "input",
            "label": "挑战次数",
            "inputs": [
                {
                    "name": "次数",
                    "pipeline_type": "int",
                    "default": "3"
                }
            ],
            "pipeline_override": {
                "SelectAttackSlot": {
                    "max_hit": "{次数}"
                }
            }
        },
        "体力选择": {
            "type": "select",
            "cases": [
                {
                    "name": "铁矿",
                    "pipeline_override": {
                        "IronByEnergy": {
                            "enabled": true
                        }
                    }
                },
                {
                    "name": "金矿",
                    "pipeline_override": {
                        "GoldByEnergy": {
                            "enabled": true
                        }
                    }
                },
                {
                    "name": "砂矿",
                    "pipeline_override": {
                        "GravelByEnergy": {
                            "enabled": true
                        }
                    }
                },
                {
                    "name": "杀猪",
                    "pipeline_override": {
                        "PigByEnergy": {
                            "enabled": true
                        }
                    }
                }
            ]
        },
        "体力使用次数": {
            "type": "input",
            "label": "体力使用次数",
            "inputs": [
                {
                    "name": "次数",
                    "pipeline_type": "string",
                    "default": "6"
                }
            ],
            "pipeline_override": {
                "InputAutoCount": {
                    "action": {
                        "param": {
                            "input_text": "{次数}"
                        }
                    }
                }
            }
        },
        "购买宠物素材": {
            "type": "switch",
            "label": "购买宠物素材",
            "default_case": "No",
            "cases": [
                {
                    "name": "Yes",
                    "pipeline_override": {
                        "ExchangePetResourcePage": {
                            "enabled": true
                        }
                    },
                    "option": [
                        "选择宠物素材"
                    ]
                },
                {
                    "name": "No",
                    "pipeline_override": {
                        "ExchangePetResourcePage": {
                            "enabled": false
                        }
                    }
                }
            ]
        },
        "选择宠物素材": {
            "type": "select",
            "label": "选择宠物素材",
            "default_case": "羊毛",
            "cases": [
                {
                    "name": "羊毛",
                    "pipeline_override": {
                        "PurplePetResourceNotSoldout": {
                            "recognition": {
                                "param": {
                                    "roi": [30,898,204,255]
                                }
                            },
                            "action": {
                                "param": {
                                    "target": [98,1101,70,32]
                                }
                            }
                        },
                        "OrangePetResourceNotSoldout": {
                            "recognition": {
                                "param": {
                                    "roi": [28,614,208,257]
                                }
                            },
                            "action": {
                                "param": {
                                    "target": [100,818,68,35]
                                }
                            }
                        }
                    }
                },
                {
                    "name": "鸡蛋",
                    "pipeline_override": {
                        "PurplePetResourceNotSoldout": {
                            "recognition": {
                                "param": {
                                    "roi": [258,899,202,249]
                                }
                            },
                            "action": {
                                "param": {
                                    "target": [329,1103,73,30]
                                }
                            }
                        },
                        "OrangePetResourceNotSoldout": {
                            "recognition": {
                                "param": {
                                    "roi": [257,615,206,254]
                                }
                            },
                            "action": {
                                "param": {
                                    "target": [331,820,69,30]
                                }
                            }
                        }
                    }
                },
                {
                    "name": "精油",
                    "pipeline_override": {
                        "PurplePetResourceNotSoldout": {
                            "recognition": {
                                "param": {
                                    "roi": [486,616,208,254]
                                }
                            },
                            "action": {
                                "param": {
                                    "target": [560,820,68,31]
                                }
                            }
                        },
                        "OrangePetResourceNotSoldout": {
                            "recognition": {
                                "param": {
                                    "roi": [488,335,203,252]
                                }
                            },
                            "action": {
                                "param": {
                                    "target": [558,538,75,31]
                                }
                            }
                        }
                    }
                }
            ]
        }
    },
    "import": [
        "resource/preset/MainAccount.json",
        "resource/preset/SideAccount.json"
    ]
}