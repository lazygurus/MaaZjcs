{
    // 小推车
    "Cart": {
        "next": [
            "[JumpBack]LeaveCurrentPage",
            "[JumpBack]CloseGift",
            "[JumpBack]HomePage",
            "SearchCartLeft"
        ]
    },
    "SearchCartLeft": {
        "next": [
            "OpenCart",
            "LeftEdgeInSearchCart",
            "[JumpBack]SwipeLeft"
        ]
    },
    "SearchCartRight": {
        "next": [
            "OpenCart",
            "RightEdgeInSearchCart",
            "[JumpBack]SwipeRight"
        ]
    },
    "OpenCart": {
        "recognition": {
            "type": "TemplateMatch",
            "param": {
                "template": [
                    "furniture/cart_light_empty.png",
                    "furniture/cart_light_empty_snow.png",
                    "furniture/cart_light_full.png",
                    "furniture/cart_night_empty_snow.png",
                    "furniture/cart_night_full.png"
                ]
            }
        },
        "action": {
            "type": "Click"
        },
        "next": [
            "[JumpBack]ReceivePrize",
            "[JumpBack]ReceiveCartPrize",
            "[JumpBack]CartPage",
            "End"
        ],
        "post_delay": 2000
    },
    "LeftEdgeInSearchCart": {
        "recognition": {
            "type": "TemplateMatch",
            "param": {
                "template": [
                    "furniture/airship1.png",
                    "furniture/airship2.png",
                    "furniture/airship3.png"
                ]
            }
        },
        "next": [
            "SearchCartRight"
        ]
    },
    "RightEdgeInSearchCart": {
        "recognition": {
            "type": "TemplateMatch",
            "param": {
                "template": [
                    "furniture/fireplace_light1.png",
                    "furniture/fireplace_light_snow1.png",
                    "furniture/fireplace_night1.png",
                    "furniture/fireplace_night2.png",
                    "furniture/fireplace_night_snow1.png",
                    "furniture/fireplace_night_snow2.png"
                ]
            }
        }
    },
    "CartPage": {
        "recognition": {
            "type": "OCR",
            "param": {
                "expected": [
                    "小推车"
                ]
            }
        },
        "action": {
            "type": "Click",
            "param": {
                "target": [308,1184,110,49]
            }
        }
    },
    "ReceiveCartPrize": {
        "recognition": {
            "type": "OCR",
            "param": {
                "expected": [
                    "一键领取"
                ]
            }
        },
        "action": {
            "type": "Click"
        },
        "max_hit": 1
    }
}