    "StuckHandler": {
        "focus": {
            "Node.Action.Starting": {
                "content": "启动流程卡顿或超时，已关闭游戏",
                "display": [
                    "log",
                    "toast"
                ]
            }
        },
        "action": {
            "type": "StopApp",
            "param": {
                "package": "com.leiting.zjcs"
            }
        },
        "next": [
            "RestartGame"
        ]
    },
    "RestartGame": {
        "post_delay": 5000,
        "next": [
            "StartUp"
        ]
    }
}