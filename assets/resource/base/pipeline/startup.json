{
    "StartUp": {
        "post_wait_freezes": 1000,
        "timeout": 60000,
        "next": [
            "StartGame",
            "[JumpBack]HomeLoading",
            "[JumpBack]TextLoading",
            "[JumpBack]RecognizeResourceList",
            "[JumpBack]DownLoading",
            "[JumpBack]ConfirmButton",
            "[JumpBack]Initialization",
            "Login",
            "[JumpBack]CloseAnnouncement",
            "EnterGame"
        ]
    },
    "StartGame": {
        "recognition": {
            "type": "TemplateMatch",
            "param": {
                "template": [
                    "icon.png"
                ]
            }
        },
        "action": {
            "type": "Click"
        },
        "next": [
            "[JumpBack]HomeLoading",
            "[JumpBack]TextLoading",
            "[JumpBack]RecognizeResourceList",
            "[JumpBack]DownLoading",
            "[JumpBack]ConfirmButton",
            "[JumpBack]Initialization",
            "Login",
            "[JumpBack]CloseAnnouncement",
            "EnterGame"
        ]
    },
    "HomeLoading": {
        "recognition": {
            "type": "TemplateMatch",
            "param": {
                "roi": [
                    284,
                    563,
                    151,
                    154
                ],
                "template": [
                    "homeicon.png"
                ]
            }
        },
        "next": [
            "WaitHomeLoadingGone"
        ],
        "timeout": 60000,
        "on_error": [
            "StuckHandler"
        ]
    },
    "TextLoading": {
        "recognition": {
            "type": "OCR",
            "param": {
                "roi": [
                    236,
                    417,
                    264,
                    47
                ],
                "expected": [
                    "健康游戏忠告"
                ],
                "only_rec": true
            }
        },
        "next": [
            "WaitTextLoadingGone"
        ],
        "timeout": 60000,
        "on_error": [
            "StuckHandler"
        ]
    },
    "RecognizeResourceList": {
        "recognition": {
            "type": "OCR",
            "param": {
                "roi": [
                    237,
                    974,
                    166,
                    33
                ],
                "expected": [
                    "资源清单"
                ]
            }
        },
        "next": [
            "WaitRecognizeResourceListGone"
        ],
        "timeout": 60000,
        "on_error": [
            "StuckHandler"
        ]
    },
    "DownLoading": {
        "recognition": {
            "type": "OCR",
            "param": {
                "roi": [
                    183,
                    978,
                    102,
                    30
                ],
                "expected": [
                    "下载"
                ]
            }
        },
        "next": [
            "DownloadProgressWatch" // 下载进度静止满60秒视为卡顿
        ]
    },
    "ConfirmButton": {
        "recognition": {
            "type": "OCR",
            "param": {
                "roi": [
                    233,
                    707,
                    254,
                    73
                ],
                "expected": [
                    "确定"
                ]
            }
        },
        "action": {
            "type": "Click"
        },
        "next": [
            "WaitConfirmButtonGone"
        ],
        "timeout": 60000,
        "on_error": [
            "StuckHandler"
        ]
    },
    "Initialization": {
        "recognition": {
            "type": "OCR",
            "param": {
                "roi": [
                    287,
                    979,
                    103,
                    27
                ],
                "expected": [
                    "初始化"
                ]
            }
        },
        "next": [
            "WaitInitializationGone"
        ],
        "timeout": 60000,
        "on_error": [
            "StuckHandler"
        ]
    },
    "Login": {
        "recognition": {
            "type": "OCR",
            "param": {
                "roi": [
                    183,
                    728,
                    353,
                    67
                ],
                "expected": [
                    "登录",
                    "注册"
                ]
            }
        },
        "focus": {
            "Node.Recognition.Succeeded": {
                "content": "检测到登录页面，请先登录",
                "display": [
                    "log",
                    "toast"
                ]
            }
        },
        "next": [
            "WaitLoginGone"
        ],
        "timeout": 120000,
        "on_error": [
            "StuckHandler"
        ]
    },
    "CloseAnnouncement": {
        "recognition": {
            "type": "OCR",
            "param": {
                "roi": [
                    319,
                    71,
                    80,
                    50
                ],
                "expected": [
                    "公告"
                ]
            }
        },
        "action": {
            "type": "Click",
            "param": {
                "target": [
                    38,
                    1195,
                    73,
                    49
                ]
            }
        },
        "next": [
            "WaitCloseAnnouncementGone"
        ],
        "timeout": 60000,
        "on_error": [
            "StuckHandler"
        ]
    },
    "EnterGame": {
        "recognition": {
            "type": "OCR",
            "param": {
                "roi": [
                    178,
                    1037,
                    345,
                    44
                ],
                "expected": "开始游戏"
            }
        },
        "action": {
            "type": "Click"
        }
    },
    "Shutdown": {
        "action": {
            "type": "StopApp",
            "param": {
                "package": "com.leiting.zjcs"
            }
        }
    },
