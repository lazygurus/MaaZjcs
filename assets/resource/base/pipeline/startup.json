    "WaitDownLoadingGone": {
        "recognition": {
            "type": "OCR",
            "param": {
                "roi": [
                    183,
                    978,
                    102,
                    30
                ],
                "expected": [
                    "下载"
                ]
            }
        },
        "inverse": true
    },
    "WaitConfirmButtonGone": {
        "recognition": {
            "type": "OCR",
            "param": {
                "roi": [
                    233,
                    707,
                    254,
                    73
                ],
                "expected": [
                    "确定"
                ]
            }
        },
        "inverse": true
    },
    "WaitLoginGone": {
        "recognition": {
            "type": "OCR",
            "param": {
                "roi": [
                    183,
                    728,
                    353,
                    67
                ],
                "expected": [
                    "登录",
                    "注册"
                ]
            }
        },
        "inverse": true
    }
}