{
    "Buy": {
        "next": [
            "[JumpBack]LeaveCurrentPage",
            "[JumpBack]CloseGift",
            "[JumpBack]ReturnHomePage",
            "SearchLeft"
        ]
    },
    "SearchLeft": {
        "next": [
            "OpenStore",
            "LeftEdge",
            "[JumpBack]SwipeLeft"
        ]
    },
    "SearchRight": {
        "next": [
            "OpenStore",
            "RightEdge",
            "[JumpBack]SwipeRight"
        ]
    },
    "OpenStore": {
        "recognition": {
            "type": "TemplateMatch",
            "param": {
                "roi": [4,659,716,190],
                "template": [
                    "store/store1.png",
                    "store/store2.png",
                    "store/store3.png",
                    "store/store4.png"
                ]
            }
        },
        "action": "Click",
        "post_delay": 2000,
        "next": [
            "Groceries"  // 先买杂货商店
        ],
        "on_error": [
            "Buy"  // 如果没能进入杂货店页面就重新来
        ]
    },
    "Groceries": {
        "recognition": {
            "type": "OCR",
            "param": {
                "roi": [
                    146,
                    1171,
                    566,
                    96
                ],
                "expected": [
                    "杂货"
                ]
            }
        },
        "action": {
            "type": "Click"
        },
        "post_delay": 1000,
        "next": [
            "GroceriesPurchase"
        ]
    },
    "GroceriesPurchase": {
        "next": [
            "[JumpBack]GrocerySlot1",
            "[JumpBack]GrocerySlot2",
            "[JumpBack]GrocerySlot3",
